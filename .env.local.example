# Base URL of the backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Simplified auth headers for this exercise — swap for real session values later
NEXT_PUBLIC_TENANT_ID=t1
NEXT_PUBLIC_USER_ID=u1

# Set to "true" to run the UI against bundled seed data instead of a live backend.
# Useful while the backend team's API isn't ready yet.
NEXT_PUBLIC_USE_MOCK_DATA=true
